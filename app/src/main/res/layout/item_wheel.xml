<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="136dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_home_spin_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:padding="8dp">

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="@font/inter_semibold"
        android:maxLines="2"
        android:text="@string/wheel_question"
        android:textColor="@color/color_main_text"
        android:textSize="15sp"
        app:layout_constraintEnd_toStartOf="@id/preview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/action_row"
        android:layout_width="0dp"
        android:layout_height="38dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@id/preview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_name">

        <TextView
            android:id="@+id/btn_edit"
            android:layout_width="76dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_primary_red_16"
            android:fontFamily="@font/inter_semibold"
            android:gravity="center"
            android:text="@string/edit"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_soft_panel_16"
            android:contentDescription="@string/delete"
            android:padding="8dp"
            android:src="@drawable/ic_delete_red" />

        <ImageButton
            android:id="@+id/btn_duplicate"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_soft_panel_16"
            android:contentDescription="@string/duplicate"
            android:padding="8dp"
            android:src="@drawable/ic_duplicate_red" />
    </LinearLayout>

    <com.example.spinwheel.widget.MiniWheelPreviewView
        android:id="@+id/preview"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
